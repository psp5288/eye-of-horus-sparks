# ========================================
# Eye of Horus: Sparks — Environment Config
# Copy this file to .env and fill in values
# ========================================

# ── Twitter / X API ───────────────────────────────────────────────
# Required for live sentiment signals (Iris module)
TWITTER_API_KEY=your_key_here
TWITTER_API_SECRET=your_secret_here
TWITTER_BEARER_TOKEN=Bearer your_token_here
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# ── Weather API ───────────────────────────────────────────────────
# OpenWeatherMap — https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_key_here

# ── Ticketmaster API ──────────────────────────────────────────────
# Optional — for ticket velocity signal
TICKETMASTER_API_KEY=your_ticketmaster_key_here

# ── Claude / Anthropic ────────────────────────────────────────────
# Required for all AI features (Oracle + Sparks recommendations)
# Get key at: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-your_key_here
CLAUDE_MODEL=claude-opus-4-7

# ── Database ──────────────────────────────────────────────────────
# SQLite (default for local dev), Postgres for prod
DATABASE_URL=sqlite:///./eye_of_horus.db

# ── Redis ─────────────────────────────────────────────────────────
# Optional — for caching scenario generation results
REDIS_URL=redis://localhost:6379

# ── App Config ────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development
VERTICAL=sparks

# ── Hackathon Metadata ────────────────────────────────────────────
HACKATHON_START=2025-04-21
HACKATHON_END=2025-04-26
