# ========================================
# Eye of Horus: Sparks — Environment Config
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ========================================

# --- Claude API ---
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-opus-4-7-20250514

# --- Twitter / X API v2 ---
TWITTER_BEARER_TOKEN=your-bearer-token-here
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret

# --- OpenWeatherMap ---
OPENWEATHER_API_KEY=your-openweather-key-here

# --- Ticketmaster ---
TICKETMASTER_KEY=your-ticketmaster-key-here

# --- App Config ---
APP_ENV=development
DEBUG=True
SECRET_KEY=change-this-in-production

# --- Vertical ---
VERTICAL=sparks

# --- Database (optional for MVP, SQLite works locally) ---
DATABASE_URL=sqlite:///./eye_of_horus.db
# For PostgreSQL: postgresql://user:password@localhost:5432/eye_of_horus

# --- Redis (optional, for caching) ---
REDIS_URL=redis://localhost:6379

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Simulation ---
DEFAULT_AGENT_COUNT=10000
MAX_SIMULATION_SECONDS=600
CLAUDE_SAMPLE_AGENTS_PER_TICK=10
